generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  SEO_MANAGER
  CONTENT_WRITER
  DEVELOPER
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SeoGlobal {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model SeoMatch {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
model SeoLeague {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model SeoPlayer {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
model SeoPage {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
