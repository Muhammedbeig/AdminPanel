generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  SEO_MANAGER
  CONTENT_WRITER
  DEVELOPER
}

// ✅ UPDATED: User model now supports Author Profiles for Blogs
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)

  // New Author Fields
  name         String?
  image        String?  // Profile picture URL
  bio          String?  @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relation to Blog Posts
  posts        BlogPost[]
}

// --- EXISTING SEO MODELS ---

model SeoGlobal {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model SeoMatch {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model SeoLeague {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model SeoPlayer {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model SeoPage {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}


model BlogCategory {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
}

model BlogPost {
  id            Int      @id @default(autoincrement())
  
  // Core Content
  title         String
  slug          String   @unique
  excerpt       String?  @db.Text
  content       String   @db.LongText // Rich HTML content
  featuredImage String?
  
  // Organization
  categoryId    Int?
  category      BlogCategory? @relation(fields: [categoryId], references: [id])
  
  // SEO Fields (Matches your guidelines)
  metaTitle       String?
  metaDescription String? @db.Text
  keywords        String? // Comma-separated
  
  // Advanced SEO Overrides
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  
  // Status
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  
  // Author Linking
  authorId      Int
  author        User      @relation(fields: [authorId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SystemSetting {
  id                Int      @id @default(1)
  
  // Branding
  logo              String?
  favicon           String?
  
  // Panel Identity
  siteName          String?  @default("Admin Panel") // This controls the "Panel Title"
  supportEmail      String?
  contactNumber     String?
  address           String?  @db.Text
  
  // Config
  defaultLanguage   String   @default("en")
  timezone          String   @default("UTC")
  maintenanceMode   Boolean  @default(false)
  googleAnalyticsId String?

  updatedAt         DateTime @updatedAt
}